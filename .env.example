# ============================================================
# D'Luxury Industrial Platform - Variáveis de Ambiente
# ============================================================

# --- BANCO DE DADOS (Neon PostgreSQL) ---
# Crie um projeto em: https://neon.tech
# Cole a string de conexão aqui:
DATABASE_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require"

# --- AUTENTICAÇÃO (NextAuth v5) ---
# Gere com: openssl rand -base64 32
AUTH_SECRET="sua_chave_secreta_aqui"

# URL da aplicação (substitua pelo seu domínio na Vercel)
NEXTAUTH_URL="https://seu-projeto.vercel.app"
NEXT_PUBLIC_APP_URL="https://seu-projeto.vercel.app"

# --- GEMINI / GOOGLE AI ---
# Obtenha em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="sua_chave_api_gemini"
GOOGLE_GENERATIVE_AI_API_KEY="sua_chave_api_gemini"

# --- UPSTASH REDIS (opcional) ---
# Obtenha em: https://upstash.com
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# --- SENTRY (opcional) ---
SENTRY_ORG="sua-organizacao"
SENTRY_PROJECT="marcenai"